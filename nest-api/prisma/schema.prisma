generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  region    String
  address   String
  village   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  devices   Device[]
  users     User[]
  securityContacts SecurityContact[]
  technicians      Technician[]

  @@map("branch")
}

model Device {
  id             String   @id
  name           String   @default("AI Vandalism Detection")
  branchId       Int
  status         String   @default("online")
  incidentStatus String   @default("safe")
  lat            Float
  lng            Float
  address        String

  // Hardware Status
  cameraConnected Boolean  @default(true)
  esp32Connected  Boolean  @default(true)
  gpsSatellites   Int      @default(0)

  ipAddress      String?
  province       String?
  district       String?
  sector         String?
  cell           String?
  village        String?
  lastData       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  branch         Branch   @relation(fields: [branchId], references: [id], map: "Device_branchId_fkey")
  incidents      Incident[]
  securityContacts SecurityContact[] @relation("DeviceSecurityContacts")

  @@index([branchId], map: "Device_branchId_fkey")
  @@map("device")
}

model SecurityContact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  branchId  Int
  
  address   String?
  province  String?
  district  String?
  sector    String?
  cell      String?
  village   String?
  lat       Float?
  lng       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id])
  devices   Device[] @relation("DeviceSecurityContacts")

  @@map("security_contact")
}

model Technician { 
   id              String   @id @default(uuid()) 
   staffId         String   @unique 
   fullName        String 
   email           String   @unique 
   phone           String 
   profileImage    String?  // Path to the image file 
   faceToken       Json?    // AI face vector data 
   branchId        Int 
   role            String   // e.g., "Senior Technician" 
   status          String   @default("ACTIVE") 
   createdAt       DateTime @default(now()) 
   updatedAt       DateTime @updatedAt
   
   branch          Branch   @relation(fields: [branchId], references: [id])

   @@map("technician")
}

model Incident { 
   id              String   @id @default(uuid()) 
   deviceId        String 
 
   // AI Results
   aiClass         IncidentClass? @default(SUSPICIOUS)
   aiConfidence    Float?    // e.g., 0.98
   alertType       String?   // e.g., "THREAT"
   
   // Evidence & Logic
   videoPath       String?   // URL to video evidence
   alertStatus     Boolean  @default(false) // true=thief, false=suspicious
   
   // Device Status Data from FastAPI
   pirSensor       String?   // e.g., "A"
   servoPosition   Int?      // e.g., 0
   gpsLatitude     Float? 
   gpsLongitude    Float? 

   // Dynamic AI Summary
   aiSummary       String?   @db.Text

   // Workflow Status
   status          IncidentStatus @default(ACTIVE)

   // Timestamp
   time            DateTime @default(now()) 
 
   device          Device   @relation(fields: [deviceId], references: [id]) 
 
   @@index([deviceId]) 
   @@map("incident") 
}

enum IncidentClass {
  VANDAL
  CLIMBING
  CUTTING_WIRES
  OPENING_BOX
  SUSPICIOUS
  AUTHORIZED_TECH
  @@map("incident_class")
}

enum IncidentStatus {
  ACTIVE
  PENDING
  SOLVED
  FALSE_ALARM

  @@map("incident_status")
}
model Location {
  id            Int    @id @default(autoincrement())
  province_name String @db.VarChar(100)
  district_name String @db.VarChar(100)
  sector_name   String @db.VarChar(100)
  cell_name     String @db.VarChar(100)
  village_name  String @db.VarChar(100) @default("")
  cell_id       Int    @default(0)

  @@unique([province_name, district_name, sector_name, cell_name, village_name])
  @@map("locations")
}

model User {
  id                 Int         @id @default(autoincrement())
  fullName           String
  email              String      @unique(map: "User_email_key")
  password           String
  role               Role
  status             UserStatus  @default(ENABLED)
  mustChangePassword Boolean     @default(false)
  branchId           Int?
  fcmToken           String?     @db.Text
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  branch             Branch?     @relation(fields: [branchId], references: [id], map: "User_branchId_fkey")

  @@index([branchId], map: "User_branchId_fkey")
  @@map("user")
}

enum Role {
  HQ_ADMIN
  BRANCH_USER

  @@map("user_role")
}

enum UserStatus {
  ENABLED
  DISABLED

  @@map("user_status")
}
