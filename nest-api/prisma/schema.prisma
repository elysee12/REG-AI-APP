generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  region    String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  devices   Device[]
  users     User[]
  securityContacts SecurityContact[]

  @@map("branch")
}

model Device {
  id             String   @id
  name           String   @default("AI Vandalism Detection")
  branchId       Int
  status         String   @default("online")
  incidentStatus String   @default("safe")
  lat            Float
  lng            Float
  address        String

  ipAddress      String?
  province       String?
  district       String?
  sector         String?
  cell           String?
  lastData       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  branch         Branch   @relation(fields: [branchId], references: [id], map: "Device_branchId_fkey")
  incidents      Incident[]
  securityContacts SecurityContact[] @relation("DeviceSecurityContacts")

  @@index([branchId], map: "Device_branchId_fkey")
  @@map("device")
}

model SecurityContact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  branchId  Int
  
  address   String?
  province  String?
  district  String?
  sector    String?
  cell      String?
  lat       Float?
  lng       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id])
  devices   Device[] @relation("DeviceSecurityContacts")

  @@map("security_contact")
}

model Incident {
  id        String   @id @default(uuid())
  deviceId  String
  type      String
  severity  String
  status    String   @default("active")
  time      DateTime @default(now())
  motionStatus   String?
  vibrationStatus String?
  accelX         Float?
  accelY         Float?
  accelZ         Float?
  accelStatus    String?
  aiClass        String?
  aiConfidence   Float?
  alertStatus    String?
  imagePath      String?
  videoPath      String?
  sourceNote     String?

  device    Device   @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@map("incident")
}

model Location {
  id            Int    @id @default(autoincrement())
  province_name String @db.VarChar(100)
  district_name String @db.VarChar(100)
  sector_name   String @db.VarChar(100)
  cell_name     String @db.VarChar(100)
  cell_id       Int    @default(0)

  @@unique([province_name, district_name, sector_name, cell_name])
  @@map("locations")
}

model User {
  id                 Int         @id @default(autoincrement())
  fullName           String
  email              String      @unique(map: "User_email_key")
  password           String
  role               Role
  status             UserStatus  @default(ENABLED)
  mustChangePassword Boolean     @default(false)
  branchId           Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  branch             Branch?     @relation(fields: [branchId], references: [id], map: "User_branchId_fkey")

  @@index([branchId], map: "User_branchId_fkey")
  @@map("user")
}

enum Role {
  HQ_ADMIN
  BRANCH_USER

  @@map("user_role")
}

enum UserStatus {
  ENABLED
  DISABLED

  @@map("user_status")
}
