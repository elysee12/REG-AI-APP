# Database Configuration
DATABASE_URL="mysql://user:password@localhost:3306/reg_ai"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Frontend URL (for email links)
FRONTEND_URL="http://localhost:5173"

# SMTP Configuration for Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"

# For Gmail, you need to:
# 1. Enable 2-Factor Authentication
# 2. Create an App Password at: https://myaccount.google.com/homepasswords
# 3. Use the App Password as SMTP_PASS

# WhatsApp Configuration (Twilio Example)
WHATSAPP_API_SID="your_twilio_sid"
WHATSAPP_API_TOKEN="your_twilio_auth_token"
WHATSAPP_FROM_NUMBER="whatsapp:+14155238886"

# For other providers, configure the service accordingly
